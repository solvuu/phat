{
  "ocaml.sandbox": {
    "kind": "dune",
    "root": "${firstWorkspaceFolder}"
  },
  "editor.formatOnSave": true,
  "[ocaml]": {
    "editor.defaultFormatter": "ocamllabs.ocaml-platform"
  },
  "terminal.integrated.profiles.linux": {
    "bash": {
      "path": "/bin/bash",
      "icon": "terminal-bash"
    }
  },
  "terminal.integrated.defaultProfile.linux": "bash"
}
